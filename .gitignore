# ─────────────────────────────────────────────────────────────
# Secrets & environment
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.template

# ─────────────────────────────────────────────────────────────
# Python (backend + venv at repo root)
# ─────────────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

__pycache__/
*.py[cod]
*$py.class
*.so

# Build / packaging
build/
dist/
*.egg-info/
.eggs/
wheels/
*.egg
MANIFEST

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

# Jupyter
.ipynb_checkpoints/

# ASGI / dev server artifacts
*.sqlite3
*.db

# ─────────────────────────────────────────────────────────────
# Node / Vite (frontend-specific ignores live in frontend/.gitignore)
# This is a safety net in case frontend/ is moved or copied.
# ─────────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─────────────────────────────────────────────────────────────
# Docker
# ─────────────────────────────────────────────────────────────
# Keep docker-compose.yml tracked; ignore runtime volumes only.
postgres_data/

# ─────────────────────────────────────────────────────────────
# IDE / editors
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln

# Cursor user-level caches (project rules under .cursor/ stay tracked)
.cursor

# ─────────────────────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

